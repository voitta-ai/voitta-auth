# voitta-auth configuration

# Microsoft Entra ID / Azure AD (public client — no secret required)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id

# Google OAuth2 (GCP desktop app)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Okta OIDC (public client with PKCE)
OKTA_DOMAIN=your-org.okta.com
OKTA_CLIENT_ID=your-okta-client-id

# OAuth redirect settings
REDIRECT_PORT=53214

# MCP proxy settings
PROXY_PORT=18765
VOITTA_RAG_URL=https://rag.voitta.ai

# Edit proxy settings (for workspace MCP servers)
EDIT_PROXY_PORT=18766
EDIT_PROXY_URL=http://localhost:8000
EDIT_MCP_ENV_PATH=~/DEVEL/google_workspace_mcp/.env
GOOGLE_MCP_DIR=~/DEVEL/google_workspace_mcp

# Jira / Atlassian MCP (via sooperset/mcp-atlassian)
# Paste a full Jira URL to auto-detect server and project, e.g.:
# JIRA_URL=https://yourorg.atlassian.net/jira/software/projects/PROJ/issues/
JIRA_URL=
JIRA_EMAIL=your-jira-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT=
JIRA_MCP_PORT=18767
JIRA_MCP_ENV_PATH=~/DEVEL/mcp-atlassian/.env
JIRA_MCP_DIR=~/DEVEL/mcp-atlassian
